# ============================================================
# WebWA Gateway — Backend Environment Variables
# Salin file ini ke .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke Git!
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Supabase ---
# Gunakan service_role key (bukan anon key) untuk backend
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- CORS ---
# Domain frontend yang diizinkan mengakses API internal
# Pisahkan dengan koma jika lebih dari satu
FRONTEND_URL=http://localhost:5173

# --- Rate Limiter ---
# Maks request per menit per IP untuk endpoint eksternal
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# --- Session Storage ---
# Folder penyimpanan sesi WhatsApp lokal (LocalAuth)
WA_SESSION_PATH=./.wwebjs_auth

# --- Puppeteer / Chrome ---
# Isi jika ingin menggunakan Chromium kustom (kosongkan untuk auto-detect)
PUPPETEER_EXECUTABLE_PATH=
