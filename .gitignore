# ============================================================
# WebWA Gateway — .gitignore
# ============================================================

# --- Dependencies ---
node_modules/
**/node_modules/

# --- Environment Variables (JANGAN PERNAH di-commit!) ---
.env
**/.env
!.env.example
!**/.env.example

# --- WhatsApp Session Auth (berisi credential sensitif) ---
.wwebjs_auth/
**/.wwebjs_auth/
.wwebjs_cache/
**/.wwebjs_cache/

# --- Build Output ---
dist/
build/
frontend/dist/
frontend/build/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Runtime / OS ---
.DS_Store
Thumbs.db
*.pid
*.pid.lock

# --- Editor ---
.vscode/
.idea/
*.swp
*.swo

# --- Coverage ---
coverage/
.nyc_output/

# --- Docker ---
# Jangan ignore docker-compose.override.yml jika ada
docker-compose.override.yml

# --- Temp ---
tmp/
temp/
